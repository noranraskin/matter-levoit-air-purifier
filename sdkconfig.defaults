CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# ── BLE (required for Matter commissioning) ──
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_ENABLE_CONN_REATTEMPT=n

# ── Wi-Fi & IPv6 ──
CONFIG_LWIP_IPV6_AUTOCONFIG=y
CONFIG_LWIP_HOOK_IP6_ROUTE_DEFAULT=y
CONFIG_LWIP_HOOK_ND6_GET_GW_DEFAULT=y
CONFIG_LWIP_IPV6_NUM_ADDRESSES=6

# Disable SoftAP — not needed for BLE-based commissioning.
# (All official esp-matter examples also disable this.)
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n

# ── Partition Table ──
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0xC000

# ── Device Identity ──
CONFIG_DEVICE_VENDOR_ID=0xFFF1
CONFIG_DEVICE_PRODUCT_ID=0x8001

# ── Commissioning / Pairing ──
# NOTE: On ESP32, the Kconfig symbols for passcode/discriminator are not
# sourced by the platform Kconfig. The device uses CHIP's compiled defaults:
#   Discriminator: 3840 (0xF00)
#   Passcode: 20202021
# These cannot be changed via sdkconfig on ESP32 — they are set at compile
# time in the connectedhomeip SDK.

# ── Matter Console (useful for development / factory reset via serial) ──
CONFIG_ENABLE_CHIP_SHELL=y

# ── OTA ──
CONFIG_ENABLE_OTA_REQUESTOR=y

# ── mbedTLS ──
CONFIG_MBEDTLS_HKDF_C=y

# ── FreeRTOS ──
CONFIG_FREERTOS_UNICORE=y

# ── Dynamic Endpoints ──
# Set higher than needed to leave room for internal endpoints (OTA, etc.)
# Currently using 1 endpoint (Air Purifier), full build uses 4.
CONFIG_ESP_MATTER_MAX_DYNAMIC_ENDPOINT_COUNT=8

# ── Button ──
CONFIG_BUTTON_PERIOD_TIME_MS=20
CONFIG_BUTTON_LONG_PRESS_TIME_MS=5000

# ── Enable only clusters we need for minimal build ──
CONFIG_SUPPORT_FAN_CONTROL_CLUSTER=y

# ── Clusters needed for full build (disabled for now) ──
CONFIG_SUPPORT_AIR_QUALITY_CLUSTER=n
CONFIG_SUPPORT_HEPA_FILTER_MONITORING_CLUSTER=n
CONFIG_SUPPORT_PM2_5_CONCENTRATION_MEASUREMENT_CLUSTER=n
CONFIG_SUPPORT_MODE_SELECT_CLUSTER=n

# ── Disable unused clusters to save flash ──
CONFIG_SUPPORT_ACCOUNT_LOGIN_CLUSTER=n
CONFIG_SUPPORT_ACTIVATED_CARBON_FILTER_MONITORING_CLUSTER=n
CONFIG_SUPPORT_APPLICATION_BASIC_CLUSTER=n
CONFIG_SUPPORT_APPLICATION_LAUNCHER_CLUSTER=n
CONFIG_SUPPORT_AUDIO_OUTPUT_CLUSTER=n
CONFIG_SUPPORT_BOOLEAN_STATE_CONFIGURATION_CLUSTER=n
